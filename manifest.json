{
  "manifest_version": 3,
  "name": "DrwdUtilies UwU",
  "description": "Trust me bro this is totally a quality-of-life mod for drednot.io and definitely not a prank",
  "version": "6.9",
  "icons": {
    "16": "icon/icon16.png",
    "32": "icon/icon32.png",
    "48": "icon/icon48.png",
    "64": "icon/icon64.png",
    "128": "icon/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://drednot.io/", "https://test.drednot.io/"],
      "js": ["dist/content.js", "dist/content_plugin.js"],
      "css": ["dist/content.css"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    },
    {
      "matches": ["https://drednot.io/", "https://test.drednot.io/"],
      "js": ["dist/page_plugin.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "permissions": ["storage", "declarativeNetRequest", "cookies", "tabs", "identity"],
  "host_permissions": [
    "https://test.drednot.io/*",
    "https://drednot.io/*",
    "https://*.supabase.co/*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "bridge/pageMain.js",
        "bridge/pageBridge.js",
        "utils/*.js",
        "asset/fontawesome/css/all.css",
        "asset/fontawesome/webfonts/*",
        "plugins/*.css",
        "storage/OPFS.js",
        "storage/config.js",
        "ui/*.css",
        "ui/*.js"
      ],
      "matches": ["https://drednot.io/*", "https://test.drednot.io/*"]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}